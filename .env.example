# === Настройки Gmail SMTP ===
# Ваш адрес Gmail
GMAIL_ADDRESS=your_email@gmail.com

# Пароль приложения Gmail (НЕ обычный пароль!)
# Инструкция: https://support.google.com/accounts/answer/185833
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# === Пути ===
# Путь к файлу учётных данных Google API (OAuth2 или сервисный аккаунт)
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json

# Папка для сохранения сгенерированных документов
OUTPUT_DIR=output

# Папка для кэшированных шаблонов
TEMPLATES_CACHE_DIR=templates_cache

# === База данных ===
DATABASE_PATH=app_database.db
